GITHUB_TOKEN=your_github_token_here
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
COLLECTION_NAME=codebase_oracle

# Ollama Cloud / OpenAI-Compatible Endpoint
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_BASE_URL=https://api.ollama.com/v1
OLLAMA_MODEL=llama3

# Gemini Configuration (for embeddings)
GOOGLE_API_KEY=your_gemini_api_key_here

VAPI_SECRET=your_vapi_secret_here

# Deep Code Ingestion (set to false to skip source file ingestion)
INGEST_SOURCE_FILES=true
MAX_FILE_SIZE_BYTES=51200
MAX_SOURCE_FILES=200
