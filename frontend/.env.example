# ─── Vapi Web SDK ──────────────────────────────────────────────────────────────
# Your Vapi Public Key — from https://dashboard.vapi.ai → Account → API Keys
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here

# ─── Backend (FastAPI on Railway) ──────────────────────────────────────────────
# The Railway deployment URL for the backend, no trailing slash
NEXT_PUBLIC_BACKEND_URL=https://your-app.railway.app
